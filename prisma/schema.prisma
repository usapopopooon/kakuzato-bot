generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum StickyMessageType {
  TEXT
  EMBED
}

enum BumpServiceKey {
  DISBOARD
  DISSOKU
}

enum AutoModRuleType {
  NO_AVATAR
  ACCOUNT_AGE
}

enum AutoModAction {
  BAN
  KICK
  TIMEOUT
}

enum AutoModActionTaken {
  BANNED
  KICKED
  TIMED_OUT
}

enum AutoModLogStatus {
  PENDING
  SUCCEEDED
  FAILED
}

model BotActivityConfig {
  id           String   @id @default("global")
  activityName String   @db.VarChar(128)
  updatedAt    DateTime @updatedAt
}

model WelcomeConfig {
  guildId               String   @id
  channelId             String
  enabled               Boolean  @default(true)
  messageContent        String   @db.Text
  bannerMessageTemplate String   @default("{displayName} さんが召喚されました！") @db.Text
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
}

model EventLogConfig {
  guildId           String   @id
  channelId         String
  enabled           Boolean  @default(true)
  enabledCategories String[] @default([])
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

model VoiceNotifyConfig {
  id              Int      @id @default(autoincrement())
  guildId         String
  voiceChannelId  String
  notifyChannelId String
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@unique([guildId, voiceChannelId])
  @@index([guildId])
  @@index([notifyChannelId])
}

model StickyMessageConfig {
  channelId    String            @id
  guildId      String
  messageId    String?
  messageType  StickyMessageType
  title        String            @default("")
  description  String            @db.Text
  color        Int?
  delaySeconds Int               @default(5)
  lastPostedAt DateTime?
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt

  @@index([guildId])
}

model BumpConfig {
  guildId   String   @id
  channelId String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model BumpReminder {
  id         Int            @id @default(autoincrement())
  guildId    String
  channelId  String         @default("")
  serviceKey BumpServiceKey
  remindAt   DateTime?
  isEnabled  Boolean        @default(true)
  roleId     String?
  createdAt  DateTime       @default(now())
  updatedAt  DateTime       @updatedAt

  @@unique([guildId, serviceKey])
  @@index([guildId])
  @@index([isEnabled, remindAt])
}

model AutoModConfig {
  guildId      String   @id
  logChannelId String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model AutoModRule {
  id                     Int             @id @default(autoincrement())
  guildId                String
  ruleType               AutoModRuleType
  isEnabled              Boolean         @default(true)
  action                 AutoModAction   @default(BAN)
  thresholdSeconds       Int?
  timeoutDurationSeconds Int?
  createdAt              DateTime        @default(now())
  updatedAt              DateTime        @updatedAt
  logs                   AutoModLog[]

  @@unique([guildId, ruleType])
  @@index([guildId])
  @@index([guildId, isEnabled])
}

model AutoModLog {
  id            Int                @id @default(autoincrement())
  guildId       String
  userId        String
  username      String
  ruleId        Int
  actionTaken   AutoModActionTaken
  reason        String             @db.Text
  status        AutoModLogStatus   @default(PENDING)
  dedupeKey     String             @unique
  failureReason String?            @db.Text
  completedAt   DateTime?
  createdAt     DateTime           @default(now())
  rule          AutoModRule        @relation(fields: [ruleId], references: [id], onDelete: Cascade)

  @@index([guildId, createdAt])
  @@index([guildId, userId, createdAt])
  @@index([ruleId])
}
