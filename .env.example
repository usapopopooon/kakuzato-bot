DISCORD_TOKEN=
WELCOME_CHANNEL_ID=

# Optional: limit the welcome banner feature to one Discord server.
WELCOME_GUILD_ID=

# Optional message content sent with the image.
# Available placeholders: {mention}, {username}, {displayName}, {guildName}, {memberCount}
WELCOME_MESSAGE_CONTENT=Welcome, {mention}!

BOT_ACTIVITY_NAME=サーバーを管理中。
JOIN_BANNER_TEMPLATE_PATH=static/img/join-banner-template.png
EVENT_LOG_CONFIG_PATH=data/event-log-configs.json
LOG_LEVEL=info
HEALTHCHECK_FILE=/tmp/kakuzato-bot-ready
