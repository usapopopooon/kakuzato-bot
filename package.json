{
  "name": "kakuzato-bot",
  "version": "0.1.0",
  "private": true,
  "description": "Discord administration bot for Kakuzato.",
  "scripts": {
    "build": "prisma generate && tsc -p tsconfig.build.json",
    "db:generate": "prisma generate",
    "db:migrate:deploy": "prisma migrate deploy",
    "db:migrate:dev": "prisma migrate dev",
    "dev": "tsx watch src/app/main.ts",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "healthcheck": "node dist/app/healthcheck.js",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "start": "node dist/app/main.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit -p tsconfig.json"
  },
  "dependencies": {
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "discord.js": "^14.20.0",
    "pg": "^8.22.0",
    "pino": "^9.7.0",
    "sharp": "^0.34.2",
    "zod": "^3.25.67"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^22.15.32",
    "@types/pg": "^8.20.0",
    "eslint": "^10.5.0",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^17.7.0",
    "prettier": "^3.8.4",
    "prisma": "^7.8.0",
    "tsx": "^4.20.3",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.62.0",
    "vitest": "^3.2.4"
  },
  "overrides": {
    "@hono/node-server": "^1.19.13",
    "esbuild": "^0.28.1",
    "undici": "^6.26.1"
  },
  "engines": {
    "node": ">=22"
  }
}
